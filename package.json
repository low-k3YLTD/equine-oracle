{
  "name": "equine-oracle",
  "version": "3.1.0",
  "description": "Equine Oracle v3.1 - Production-grade horse-race prediction system with ML ensemble and Kelly RL agent",
  "main": "dist/server/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server/index.js",
    "start:prod": "NODE_ENV=production node dist/server/index.js",
    "dev": "nodemon --exec node --loader tsx src/server/index.ts",
    "build": "tsc && npm run build:frontend",
    "build:frontend": "vite build",
    "build:backend": "tsc",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "horse-racing",
    "prediction",
    "machine-learning",
    "ensemble",
    "catboost",
    "xgboost",
    "lightgbm",
    "kelly-criterion",
    "reinforcement-learning"
  ],
  "author": "Lowkey Group",
  "license": "MIT",
  "dependencies": {
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.5.0",
    "mysql2": "^3.6.0",
    "drizzle-orm": "^0.28.6",
    "drizzle-kit": "^0.20.7",
    "redis": "^4.6.10",

    "@trpc/server": "^10.45.0",
    "@trpc/client": "^10.45.0",
    "@trpc/react-query": "^10.45.0",

    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-query": "^3.39.3",
    "vite": "^5.0.0",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/express": "^4.17.20",
    "@types/react": "^18.2.28",
    "@typescript-eslint/eslint-plugin": "^6.7.5",
    "@typescript-eslint/parser": "^6.7.5",
    "eslint": "^8.51.0",
    "prettier": "^3.0.3",
    "nodemon": "^3.0.1",
    "tsx": "^3.14.0",
    "vitest": "^0.34.6",
    "c8": "^7.14.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
